# דופמין — Environment Variables
# Copy this to .env.local or set in Vercel dashboard

# ─── Supabase ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_premium_monthly_id
STRIPE_PRICE_PREMIUM_ANNUAL=price_premium_annual_id

# ─── Resend (Email) ───────────────────────────────
RESEND_API_KEY=re_...
NEWSLETTER_API_SECRET=your-random-secret-for-api-auth

# ─── Site ──────────────────────────────────────────
SITE_URL=https://dupaman.vercel.app

# ─── Google Sheets Backup (optional) ──────────────
GOOGLE_SHEETS_ID=your-sheets-id
GOOGLE_API_KEY=your-api-key